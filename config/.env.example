# Copy to .env and adjust (loaded by docker-compose or your shell).
# The server reads DP1_FEED_* variables from the environment.

# Database connection (use 'postgres' as hostname in Docker, 'localhost' for local dev)
DP1_FEED_DATABASE_URL=postgres://postgres:postgres@postgres:5432/dp1_feed?sslmode=disable

# API authentication key (change in production!)
DP1_FEED_API_KEY=dev-change-me

# Ed25519 signing key (64 hex chars). Generate with: openssl rand -hex 32
DP1_FEED_SIGNING_KEY_HEX=your-signing-key-here

# Optional: Sentry DSN for error tracking
DP1_FEED_SENTRY_DSN=

# Enable debug logging
DP1_FEED_LOG_DEBUG=true
