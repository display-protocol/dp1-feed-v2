# Copy to .env and adjust (loaded by docker-compose or your shell).
# The server reads DP1_FEED_* variables from the environment.

# Database connection (use 'postgres' as hostname in Docker, 'localhost' for local dev)
DP1_FEED_DATABASE_URL=postgres://postgres:postgres@postgres:5432/dp1_feed?sslmode=disable

# API authentication key (change in production!)
DP1_FEED_API_KEY=dev-change-me

# Optional publisher-scoped bearer tokens as JSON:
# DP1_FEED_PUBLISHER_TOKENS_JSON=[{"name":"Casey Reas","token":"publisher-dev-token","publisher_key":"did:key:z6Mk..."}]
DP1_FEED_PUBLISHER_TOKENS_JSON=

# Optional publisher auth overrides for the browser-based passkey flow.
# RP origins JSON example: ["http://localhost:8787"]
DP1_FEED_PUBLISHER_AUTH_RP_ID=
DP1_FEED_PUBLISHER_AUTH_RP_DISPLAY_NAME=
DP1_FEED_PUBLISHER_AUTH_RP_ORIGINS_JSON=
DP1_FEED_PUBLISHER_AUTH_SESSION_COOKIE_NAME=
DP1_FEED_PUBLISHER_AUTH_CEREMONY_COOKIE_NAME=
DP1_FEED_PUBLISHER_AUTH_DOMAIN_RESOLVER_URL=
DP1_FEED_PUBLISHER_AUTH_DOMAIN_RESOLVER_API_KEY=
DP1_FEED_PUBLISHER_AUTH_ENS_RPC_URL=

# Ed25519 signing key (64 hex chars). Generate with: openssl rand -hex 32
DP1_FEED_SIGNING_KEY_HEX=your-signing-key-here

# Optional: Sentry DSN for error tracking
DP1_FEED_SENTRY_DSN=

# Enable debug logging
DP1_FEED_LOG_DEBUG=true
