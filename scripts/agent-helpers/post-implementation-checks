#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

if [[ ! -f go.mod ]]; then
  echo "No go.mod found. Skipping Go post-implementation checks."
  exit 0
fi

if ! command -v make >/dev/null 2>&1; then
  echo "make not found; install Make to run the same gate as 'make verify' (see Makefile)."
  exit 1
fi

echo "==> make fmt (format code; see Makefile)"
make fmt

echo "==> make verify (lint + test + test-integration; see Makefile)"
make verify

echo "Post-implementation checks passed."
